{
  "manifest_version": 3,
  "name": "TimeWarden",
  "version": "0.1.0",
  "description": "Set daily time limits for distracting websites. TimeWarden tracks how long you spend and blocks a site once you hit its limit.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TimeWarden",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "alarms", "idle"]
}
